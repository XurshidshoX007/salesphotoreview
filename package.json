{
  "name": "lmj-photo-review-launcher",
  "private": true,
  "scripts": {
    "start": "node backend/src/server.mjs",
    "build:frontend": "node scripts/build-frontend.mjs",
    "build:review": "npm run build:frontend && npm run build:review-css",
    "build:review-css": "node scripts/build-review-css.mjs",
    "review": "node backend/src/server.mjs",
    "public:link": "node work/start_cloudflare_tunnel.mjs",
    "stop": "node work/stop_review_server.mjs",
    "stop:review": "node work/stop_review_server.mjs",
    "collect": "node work/run_collect_playwright.mjs",
    "collect:http": "node work/run_collect_http.mjs",
    "login:sales": "node work/open_sales_login.mjs",
    "collect:date": "node work/run_collect_playwright.mjs",
    "manifest:sync": "node work/sync_manifest.mjs",
    "analyze:photos": "python work/analyze_lmj_photos.py",
    "eval:auto-review": "node scripts/evaluate-auto-review.js",
    "brands:list": "node scripts/brands.mjs list",
    "brands:validate": "node scripts/brands.mjs validate",
    "brands:add": "node scripts/brands.mjs add",
    "brands:edit": "node scripts/brands.mjs edit",
    "migrate:brands": "node scripts/brands.mjs migrate",
    "test:brands": "node scripts/test-brands.mjs",
    "attendance:generate": "node scripts/attendance-generate.js",
    "attendance:export": "node scripts/attendance-export.js",
    "attendance:validate": "node scripts/attendance-validate.js",
    "attendance:list": "node scripts/attendance-list.js",
    "test:attendance": "node scripts/test-attendance.mjs",
    "test:review-api": "node scripts/test-review-api.mjs",
    "test:review-security": "node scripts/test-review-security.mjs",
    "test:review-ui": "node scripts/test-review-ui.mjs",
    "test:review-workflows": "node scripts/test-review-workflows.mjs",
    "test:dataset-ensure": "node scripts/test-dataset-ensure.mjs",
    "test:dataset-auto-load": "node scripts/test-dataset-auto-load.mjs",
    "test:review": "npm run build:review && npm run test:brands && npm run test:attendance && npm run test:dataset-ensure && npm run test:dataset-auto-load && npm run test:review-security && npm run test:review-api && npm run test:review-workflows && npm run test:review-ui",
    "maintenance:check": "node scripts/maintenance-cleanup.mjs",
    "maintenance:apply": "node scripts/maintenance-cleanup.mjs --apply"
  },
  "dependencies": {
    "sharp": "^0.34.3"
  },
  "optionalDependencies": {
    "playwright": "^1.60.0"
  },
  "engines": {
    "node": ">=20"
  }
}
