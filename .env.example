# Tezlik sozlamalari
COLLECT_CONCURRENCY=12
COLLECT_FLUSH_EVERY=25
COLLECT_ORDER_PREFETCH=1
COLLECT_ORDER_PAGE_SIZE=1000
COLLECT_ORDER_MAX_PAGES=100
SALES_API_TIMEOUT_MS=45000
