PORT=8765
# Lokal ishlashda bo'sh qoldirish mumkin. Alohida data katalogi kerak bo'lsa: ./data
DATA_DIR=
SALES_BASE_URL=https://lalaku.lalakusales.com
# Frontend va backend bir domenda bo'lsa bo'sh qoldiring (tavsiya).
VITE_API_BASE_URL=

TELEGRAM_BOT_TOKEN=telegram_bot_token_here
TELEGRAM_CHAT_ID=-1000000000000
# TELEGRAM_CAPTION_TITLE=(LMJ) LALAKU MAMA

# Agar Telegram gruppada Topic/Forum ishlatilsa, kerakli topic ID ni yozing.
# Oddiy gruppa uchun bo'sh qoldiring.
TELEGRAM_THREAD_ID=

# Tezlik sozlamalari
COLLECT_CONCURRENCY=12
COLLECT_FLUSH_EVERY=25
COLLECT_ORDER_PREFETCH=1
COLLECT_ORDER_PAGE_SIZE=1000
COLLECT_ORDER_MAX_PAGES=100
SALES_API_TIMEOUT_MS=45000
PHOTO_CACHE_MAX=2000
PHOTO_DISK_CACHE=1
PHOTO_FETCH_TIMEOUT_MS=8000
# Proxy bitta rasm uchun qabul qiladigan maksimal hajm (default 15 MB).
PHOTO_FETCH_MAX_BYTES=15728640
TELEGRAM_SEND_MODE=summary
# Xavfsizlik uchun odatda 0 qolsin: guruhga rasm emas, ro'yxat/link yuboriladi.
TELEGRAM_ALLOW_DIRECT_MEDIA=0
TELEGRAM_DELAY_MS=700
TELEGRAM_REVIEW_SESSION_TTL_DAYS=3650
# Ixtiyoriy: botdagi review linklar access PIN/parol o'zgarsa ham buzilmasligi uchun.
# Bo'sh bo'lsa eski tartibda REVIEW_ACCESS_SESSION_SECRET/PIN ishlatiladi.
TELEGRAM_REVIEW_SESSION_SECRET=

# Sales avtomatik login. Haqiqiy login/parolni faqat .env.local ichiga yozing.
SALES_USERNAME=your_sales_username
SALES_PASSWORD=your_sales_password

# Public web kirishi faqat PIN va server sessiya cookie orqali ishlaydi.
# URL ichidagi access/token parametrlar ataylab qo'llanmaydi.
PHOTO_CACHE_RETENTION_DAYS=1
ATTENDANCE_BACKUP_RETENTION_DAYS=14
TEST_ARTIFACT_RETENTION_DAYS=14
# Server ishga tushgach 15 daqiqadan keyin, so'ng har 24 soatda xavfsiz tozalash/arxivlash.
MAINTENANCE_AUTO_APPLY=1
MAINTENANCE_INITIAL_DELAY_MINUTES=15
MAINTENANCE_INTERVAL_HOURS=24
REVIEW_ACCESS_PIN=change_this_pin
REVIEW_ACCESS_SESSION_HOURS=24
# PINdan alohida, uzun tasodifiy qiymat tavsiya qilinadi.
REVIEW_ACCESS_SESSION_SECRET=
# Faqat cloudflared shu kompyuterda reverse proxy bo'lib ishlasa 1 qiling.
TRUST_CLOUDFLARE_PROXY=1

# Rasm proxy xavfsizligi. Bo'sh bo'lsa domen allowlist ishlamaydi,
# lekin ichki/private IP manzillar baribir bloklanadi.
PHOTO_ALLOWED_DOMAINS=

# Ixtiyoriy: default browser ochilmasa qo'lda browser yo'lini ko'rsatish mumkin.
# Chrome shart emas; Edge, Yandex, Firefox yoki boshqa brauzer exe yo'li bo'lishi mumkin.
BROWSER_PATH=

# Ma'lumot yig'ish alohida Chrome talab qilmaydi. Bo'sh qolsa Playwright ichki Chromium ishlatadi.
# Agar aniq brauzer kerak bo'lsa Chromium asosidagi exe yo'lini yoki kanalini yozing: chrome, msedge.
COLLECT_BROWSER_PATH=
COLLECT_BROWSER_CHANNEL=

# Cloudflare doimiy tunnel sozlamasi.
# Vaqtinchalik link uchun bo'sh qoldiring.
# Doimiy link uchun Cloudflare Zero Trust tunnel tokenini .env.local ichiga yozing.
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_PUBLIC_URL=https://foto-nazorat.example.com
