MAINTENANCE_INITIAL_DELAY_MINUTES=15
MAINTENANCE_INTERVAL_HOURS=24
REVIEW_ACCESS_PIN=151806
REVIEW_ACCESS_SESSION_HOURS=24

# Rasm proxy xavfsizligi. Bo'sh bo'lsa domen allowlist ishlamaydi,
# lekin ichki/private IP manzillar baribir bloklanadi.
PHOTO_ALLOWED_DOMAINS=

# Ixtiyoriy: default browser ochilmasa qo'lda browser yo'lini ko'rsatish mumkin.
# Chrome shart emas; Edge, Yandex, Firefox yoki boshqa brauzer exe yo'li bo'lishi mumkin.
BROWSER_PATH=

# Ma'lumot yig'ish alohida Chrome talab qilmaydi. Bo'sh qolsa Playwright ichki Chromium ishlatadi.
# Agar aniq brauzer kerak bo'lsa Chromium asosidagi exe yo'lini yoki kanalini yozing: chrome, msedge.
COLLECT_BROWSER_PATH=
COLLECT_BROWSER_CHANNEL=

# Cloudflare doimiy tunnel sozlamasi.
# Vaqtinchalik link uchun bo'sh qoldiring.
# Doimiy link uchun Cloudflare Zero Trust tunnel tokenini .env.local ichiga yozing.
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_PUBLIC_URL=https://foto-nazorat.example.com
